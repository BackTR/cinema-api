# .env — jangan di-commit ke git!
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://cinema_user:cinema_pass@localhost:5432/cinema_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# JWT
JWT_ACCESS_SECRET=ganti_dengan_secret_panjang_random_minimal_32_karakter
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ganti_dengan_secret_lain_yang_berbeda_minimal_32_karakter
JWT_REFRESH_EXPIRES_IN=7d

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cinemaapp.com

# Storage (S3 / MinIO)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=cinema-tickets