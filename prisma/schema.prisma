generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentGateway {
  MIDTRANS
  XENDIT
}

enum SeatStatus {
  AVAILABLE
  LOCKED
  BOOKED
}

enum SeatType {
  REGULAR
  VIP
}

enum StudioType {
  REGULAR
  PREMIUM
  IMAX
}

enum MovieFormat {
  TWO_D
  THREE_D
  IMAX
  FOUR_DX
}

enum MovieLanguage {
  INDONESIA
  ENGLISH
  SUBTITLED
}

enum PricingType {
  BASE
  WEEKEND
  HOLIDAY
  PEAK_HOUR
  PROMOTION
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  email           String    @unique
  phone           String?
  passwordHash    String    @map("password_hash")
  role            Role      @default(CUSTOMER)
  isActive        Boolean   @default(true) @map("is_active")
  avatarUrl       String?   @map("avatar_url")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  bookings        Booking[]

  @@index([isActive])
  @@index([role])
  @@map("users")
}

model Movie {
  id              String      @id @default(uuid()) @db.Uuid
  title           String
  synopsis        String
  durationMinutes Int         @map("duration_minutes")
  genre           String
  rating          String
  language        MovieLanguage @default(INDONESIA)
  format          MovieFormat   @default(TWO_D)
  trailerUrl      String?     @map("trailer_url")
  posterUrl       String?     @map("poster_url")
  director        String?
  cast            String?
  releaseDate     DateTime    @map("release_date") @db.Date
  endDate         DateTime?   @map("end_date") @db.Date
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  schedules       Schedule[]

  @@index([isActive])
  @@index([releaseDate])
  @@index([genre])
  @@index([isActive, releaseDate])
  @@map("movies")
}

model Cinema {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  address     String
  city        String
  phone       String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  studios     Studio[]

  @@index([city])
  @@index([isActive])
  @@index([city, isActive])
  @@map("cinemas")
}

model Studio {
  id        String     @id @default(uuid()) @db.Uuid
  cinemaId  String     @map("cinema_id") @db.Uuid
  name      String
  type      StudioType @default(REGULAR)
  isActive  Boolean    @default(true) @map("is_active")
  cinema    Cinema     @relation(fields: [cinemaId], references: [id])
  seats     Seat[]
  schedules Schedule[]

  // capacity dihapus — dihitung dari COUNT(seats) agar selalu sinkron
  @@index([cinemaId])
  @@index([isActive])
  @@map("studios")
}

model Seat {
  id           String         @id @default(uuid()) @db.Uuid
  studioId     String         @map("studio_id") @db.Uuid
  rowLabel     String         @map("row_label")
  seatNumber   Int            @map("seat_number")
  type         SeatType       @default(REGULAR)
  studio       Studio         @relation(fields: [studioId], references: [id])
  scheduleSeats ScheduleSeat[]

  @@unique([studioId, rowLabel, seatNumber])
  @@index([studioId])
  @@map("seats")
}

model Schedule {
  id            String         @id @default(uuid()) @db.Uuid
  movieId       String         @map("movie_id") @db.Uuid
  studioId      String         @map("studio_id") @db.Uuid
  showTime      DateTime       @map("show_time")
  endTime       DateTime       @map("end_time")
  basePrice     Decimal        @map("base_price") @db.Decimal(12, 2)
  language      MovieLanguage  @default(SUBTITLED)
  format        MovieFormat    @default(TWO_D)
  isSoldOut     Boolean        @default(false) @map("is_sold_out")
  isActive      Boolean        @default(true) @map("is_active")
  movie         Movie          @relation(fields: [movieId], references: [id])
  studio        Studio         @relation(fields: [studioId], references: [id])
  bookings      Booking[]
  scheduleSeats ScheduleSeat[]
  pricingRules  PricingRule[]

  @@index([showTime])
  @@index([endTime])
  @@index([movieId])
  @@index([studioId])
  @@index([movieId, showTime])
  @@index([isActive, showTime])
  @@index([isSoldOut])
  @@map("schedules")
}

/// Track status per kursi per jadwal — source of truth untuk seat availability
model ScheduleSeat {
  id          String       @id @default(uuid()) @db.Uuid
  scheduleId  String       @map("schedule_id") @db.Uuid
  seatId      String       @map("seat_id") @db.Uuid
  status      SeatStatus   @default(AVAILABLE)
  lockedBy    String?      @map("locked_by") @db.Uuid
  lockedUntil DateTime?    @map("locked_until")
  schedule    Schedule     @relation(fields: [scheduleId], references: [id])
  seat        Seat         @relation(fields: [seatId], references: [id])
  bookingSeat BookingSeat?

  @@unique([scheduleId, seatId])
  @@index([scheduleId, status])
  @@index([seatId])
  @@index([lockedUntil])
  @@index([status])
  @@map("schedule_seats")
}

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  scheduleId         String        @map("schedule_id") @db.Uuid
  bookingCode        String        @unique @map("booking_code")
  status             BookingStatus @default(PENDING)
  totalAmount        Decimal       @map("total_amount") @db.Decimal(12, 2)
  expiresAt          DateTime      @map("expires_at")
  expiredAt          DateTime?     @map("expired_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  user               User          @relation(fields: [userId], references: [id])
  schedule           Schedule      @relation(fields: [scheduleId], references: [id])
  seats              BookingSeat[]
  payment            Payment?

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@index([bookingCode])
  @@index([scheduleId])
  @@map("bookings")
}

/// BookingSeat mereferensi ScheduleSeat (bukan Seat langsung)
/// untuk mencegah double booking di level DB
model BookingSeat {
  id             String       @id @default(uuid()) @db.Uuid
  bookingId      String       @map("booking_id") @db.Uuid
  scheduleSeatId String       @unique @map("schedule_seat_id") @db.Uuid
  price          Decimal      @db.Decimal(12, 2)
  ticketCode     String       @unique @map("ticket_code")
  booking        Booking      @relation(fields: [bookingId], references: [id])
  scheduleSeat   ScheduleSeat @relation(fields: [scheduleSeatId], references: [id])

  // Mencegah seat yang sama dipesan 2x dalam 1 booking
  @@unique([bookingId, scheduleSeatId])
  @@index([bookingId])
  @@index([ticketCode])
  @@map("booking_seats")
}

model Payment {
  id              String         @id @default(uuid()) @db.Uuid
  bookingId       String         @unique @map("booking_id") @db.Uuid
  gatewayRef      String?        @map("gateway_ref")
  gateway         PaymentGateway @default(MIDTRANS)
  status          PaymentStatus  @default(PENDING)
  amount          Decimal        @db.Decimal(12, 2)
  gatewayResponse Json?          @map("gateway_response")
  expiredAt       DateTime?      @map("expired_at")
  paidAt          DateTime?      @map("paid_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  booking         Booking        @relation(fields: [bookingId], references: [id])

  @@index([gatewayRef])
  @@index([status])
  @@index([bookingId, status])
  @@map("payments")
}

/// Dynamic pricing rules per jadwal
/// Memungkinkan harga berbeda: weekend, VIP, promo, peak hour
model PricingRule {
  id          String      @id @default(uuid()) @db.Uuid
  scheduleId  String      @map("schedule_id") @db.Uuid
  seatType    SeatType?   @map("seat_type")
  pricingType PricingType @map("pricing_type")
  price       Decimal     @db.Decimal(12, 2)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  schedule    Schedule    @relation(fields: [scheduleId], references: [id])

  @@unique([scheduleId, seatType, pricingType])
  @@index([scheduleId])
  @@index([isActive])
  @@map("pricing_rules")
}
