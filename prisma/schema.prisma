// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role        { 
    CUSTOMER 
    ADMIN 
    STAFF 
    }
enum BookingStatus { 
    PENDING 
    CONFIRMED 
    CANCELLED 
    EXPIRED 
    }
enum PaymentStatus {
     PENDING 
     PAID 
     FAILED 
     REFUNDED 
     }
enum SeatStatus  { 
    AVAILABLE 
    LOCKED 
    BOOKED 
    }
enum SeatType    { 
    REGULAR 
    VIP 
    }
enum StudioType  { 
    REGULAR 
    PREMIUM 
    IMAX 
    }

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  phone           String?
  passwordHash    String    @map("password_hash")
  role            Role      @default(CUSTOMER)
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  bookings        Booking[]
  @@map("users")
}

model Movie {
  id              String     @id @default(uuid())
  title           String
  synopsis        String
  durationMinutes Int        @map("duration_minutes")
  genre           String
  rating          String     // "SU", "13+", "17+", "21+"
  posterUrl       String?    @map("poster_url")
  releaseDate     DateTime   @map("release_date")
  isActive        Boolean    @default(true) @map("is_active")
  schedules       Schedule[]
  @@map("movies")
}

model Cinema {
  id      String   @id @default(uuid())
  name    String
  address String
  city    String
  phone   String?
  studios Studio[]
  @@map("cinemas")
}

model Studio {
  id        String     @id @default(uuid())
  cinemaId  String     @map("cinema_id")
  name      String
  capacity  Int
  type      StudioType @default(REGULAR)
  cinema    Cinema     @relation(fields: [cinemaId], references: [id])
  seats     Seat[]
  schedules Schedule[]
  @@map("studios")
}

model Seat {
  id          String   @id @default(uuid())
  studioId    String   @map("studio_id")
  rowLabel    String   @map("row_label")  // "A", "B", "C"
  seatNumber  Int      @map("seat_number")
  type        SeatType @default(REGULAR)
  studio      Studio   @relation(fields: [studioId], references: [id])
  bookingSeats BookingSeat[]
  scheduleSeat ScheduleSeat[]
  @@unique([studioId, rowLabel, seatNumber])
  @@map("seats")
}

model Schedule {
  id           String         @id @default(uuid())
  movieId      String         @map("movie_id")
  studioId     String         @map("studio_id")
  showTime     DateTime       @map("show_time")
  basePrice    Decimal        @map("base_price") @db.Decimal(12, 2)
  isActive     Boolean        @default(true) @map("is_active")
  movie        Movie          @relation(fields: [movieId], references: [id])
  studio       Studio         @relation(fields: [studioId], references: [id])
  bookings     Booking[]
  scheduleSeats ScheduleSeat[]
  @@index([showTime])
  @@index([movieId])
  @@map("schedules")
}

// Track status per kursi per jadwal — penting untuk seat map realtime
model ScheduleSeat {
  id          String      @id @default(uuid())
  scheduleId  String      @map("schedule_id")
  seatId      String      @map("seat_id")
  status      SeatStatus  @default(AVAILABLE)
  lockedBy    String?     @map("locked_by")  // userId
  lockedUntil DateTime?   @map("locked_until")
  schedule    Schedule    @relation(fields: [scheduleId], references: [id])
  seat        Seat        @relation(fields: [seatId], references: [id])
  @@unique([scheduleId, seatId])
  @@index([scheduleId, status]) // query seat map by schedule
  @@map("schedule_seats")
}

model Booking {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  scheduleId   String        @map("schedule_id")
  bookingCode  String        @unique @map("booking_code") // "CGV-20240420-XXXX"
  status       BookingStatus @default(PENDING)
  totalAmount  Decimal       @map("total_amount") @db.Decimal(12, 2)
  expiresAt    DateTime      @map("expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id])
  schedule     Schedule      @relation(fields: [scheduleId], references: [id])
  seats        BookingSeat[]
  payment      Payment?
  @@index([userId])
  @@index([status, expiresAt]) // untuk job expire booking
  @@map("bookings")
}

model BookingSeat {
  id          String  @id @default(uuid())
  bookingId   String  @map("booking_id")
  seatId      String  @map("seat_id")
  price       Decimal @db.Decimal(12, 2)
  ticketCode  String  @unique @map("ticket_code") // untuk scan QR
  booking     Booking @relation(fields: [bookingId], references: [id])
  seat        Seat    @relation(fields: [seatId], references: [id])
  @@map("booking_seats")
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String        @unique @map("booking_id")
  gatewayRef      String?       @map("gateway_ref")
  gateway         String        // "midtrans" | "xendit"
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  gatewayResponse Json?         @map("gateway_response")
  paidAt          DateTime?     @map("paid_at")
  booking         Booking       @relation(fields: [bookingId], references: [id])
  @@map("payments")
}